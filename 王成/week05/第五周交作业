# ==================== 第一部分：数据准备 ====================

def load_corpus():
    """
    加载训练用的文本语料。
    我们会尝试加载 week4 课程提供的语料文件。
    """
    # 尝试找到 week4 的语料文件（同学们可以直接用这个）
    fallback = (
        "D:/Work/Study/week4语言模型/week4 语言模型/week4 语言模型/"
        "循环神经网络语言模型/corpus.txt"
    )

    # 如果上面的文件存在，就用它
    if os.path.exists(fallback):
        print(f"找到语料文件: {fallback}")
        with open(fallback, encoding="utf-8", errors="ignore") as f:
            return f.read()

    # 如果没找到，尝试加载当前目录下的所有 txt 文件
    txt_files = glob.glob("*.txt")
    if txt_files:
        print(f"找到语料文件: {txt_files}")
        texts = []
        for path in txt_files:
            with open(path, encoding="utf-8", errors="ignore") as f:
                texts.append(f.read())
