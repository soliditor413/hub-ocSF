"""
train_chinese_cls_rnn.py
中文句子关键词分类 —— 简单 RNN 版本

任务：5字句子中含有关键字（我）→ 在第几位就是第几类
模型：Embedding → RNN → 取最后隐藏状态 → Linear → Sigmoid
优化：Adam (lr=1e-3)   损失：MSELoss   无需 GPU，CPU 即可运行

依赖：torch >= 2.0   (pip install torch)
"""

import random
